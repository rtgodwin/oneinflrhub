if(class(model) == "oneinflmodel") {Z <- cleandata$Z}
if(type == "response") {
if(class(model) == "oneinflmodel") {
if (model$dist == "negbin") {
E_negbin(b, g, a, X, Z)
}
if (model$dist == "Poisson") {
E_pois(b, g, X, Z)
}
}
if(class(model) == "truncmodel") {
